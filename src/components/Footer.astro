---
const year = new Date().getFullYear();
---

<footer class="border-t border-border mt-24">
  <div class="max-w-4xl mx-auto px-6 py-8 flex items-center justify-between">

    <p class="font-mono text-xs text-muted">
      © {year} javibarranco
    </p>

    <div class="flex items-center gap-1">
      <a
        href="mailto:javibarrancotena@gmail.com"
        class="site-link p-2"
        aria-label="Email"
        title="Email"
      >
        <svg width="16" height="16" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
          <path d="M2.003 5.884 10 9.882l7.997-3.998A2 2 0 0 0 16 4H4a2 2 0 0 0-1.997 1.884z"/>
          <path d="M18 8.118l-8 4-8-4V14a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8.118z"/>
        </svg>
      </a>

      <a
        href="https://github.com/JaviBT"
        target="_blank"
