---
import { timeline } from '../data/experience';
---

<section id="work" class="max-w-4xl mx-auto px-6 pt-8 pb-20 fade-in">
  <div class="ascii-divider mb-12">
    <span>experience</span>
  </div>

  <div class="space-y-0">
    {timeline.map((entry, i) => (
      <div class="relative flex gap-6 pb-10 last:pb-0">

        <!-- Vertical connector -->
        <div class="flex flex-col items-center">
          <div class={`w-2 h-2 rounded-full mt-1.5 shrink-0 ${entry.current ? 'bg-accent' : 'bg-border'}`} />
          {i < timeline.length - 1 && <div class="w-px flex-1 bg-border mt-2" />}
        </div>

        <!-- Content -->
        <div class="flex-1 pb-2">
          <div class="flex flex-col sm:flex-row sm:items-baseline sm:justify-between gap-1 mb-2">
            <div class="font-mono text-sm">
              <span class="font-medium text-primary">{entry.role}</span>
              {' '}
              <span class="text-secondary">
                at{' '}
                {entry.companyUrl ? (
                  <a
                    href={entry.companyUrl}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="text-accent hover:text-accent/80 transition-colors"
                  >
                    {entry.company}
                  </a>
                ) : (
                  <span>{entry.company}</span>
                )}
              </span>
            </div>
            <span class="font-mono text-xs text-muted shrink-0">{entry.period}</span>
          </div>
          <p class="text-sm text-secondary leading-relaxed max-w-xl">{entry.description}</p>
        </div>

      </div>
    ))}
  </div>
</section>
