---
const timeline = [
  {
    role: 'Software Engineer',
    company: 'Google',
    companyUrl: 'https://google.com',
    period: '2024 – now',
    location: 'Warsaw, Poland',
    level: 'L3 → L4',
    description: 'Telemetry, data collection, and distributed pipelines for Gemini Code Assist. Go microservices, large-scale log processing, PII redaction at production scale.',
    current: true,
  },
  {
    role: 'Data Analyst Intern',
    company: 'Acciona',
    companyUrl: 'https://acciona.com',
    period: '2024',
    location: 'Madrid, Spain',
    level: null,
    description: 'AI chatbots with Vertex AI and DialogflowCX. Data extraction pipelines from APIs and PDFs via Document AI into BigQuery.',
    current: false,
  },
  {
    role: 'BS Computer Science & Mathematics',
    company: 'Universidad Autónoma de Madrid',
    companyUrl: null,
    period: '2020 – 2024',
    location: 'Madrid, Spain',
    level: 'Dual degree',
    description: 'Dual degree combining CS fundamentals with rigorous mathematics — algorithms, distributed systems, linear algebra, probability, and numerical methods.',
    current: false,
  },
];
---

<section id="work" class="max-w-4xl mx-auto px-6 py-20 fade-in">
  <div class="ascii-divider mb-12">
    <span>experience</span>
  </div>

  <div class="space-y-0">
    {timeline.map((item, i) => (
      <div class="relative flex gap-6 pb-12 last:pb-0">
        <!-- Timeline line -->
        <div class="flex flex-col items-center">
          <div class={`w-2 h-2 rounded-full mt-1.5 shrink-0 ${item.current ? 'bg-accent' : 'bg-border'}`} />
          {i < timeline.length - 1 && (
            <div class="w-px flex-1 bg-border mt-2" />
          )}
        </div>

        <!-- Content -->
        <div class="flex-1 pb-2">
          <div class="flex flex-col sm:flex-row sm:items-baseline sm:justify-between gap-1 mb-2">
            <div>
              <span class="font-mono text-sm font-medium text-primary">{item.role}</span>
              {' '}
              <span class="font-mono text-sm text-secondary">
                at{' '}
                {item.companyUrl ? (
                  <a
                    href={item.companyUrl}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="text-accent hover:text-accent/80 transition-colors"
                  >
                    {item.company}
                  </a>
                ) : (
                  <span class="text-secondary">{item.company}</span>
                )}
              </span>
            </div>
            <div class="flex items-center gap-3">
              {item.level && (
                <span class="font-mono text-xs text-muted border border-border px-2 py-0.5">{item.level}</span>
              )}
              <span class="font-mono text-xs text-muted">{item.period}</span>
            </div>
          </div>

          <p class="text-sm text-secondary leading-relaxed max-w-xl">
            {item.description}
          </p>
        </div>
      </div>
    ))}
  </div>
</section>
