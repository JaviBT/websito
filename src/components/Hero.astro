---
import SocialLinks from './SocialLinks.astro';
---

<section class="relative min-h-screen flex items-center pt-12 overflow-hidden">

  <div class="relative z-10 max-w-4xl mx-auto px-6 w-full">
    <div class="space-y-7 max-w-xs sm:max-w-sm">

      <div>
        <h1 class="font-mono text-3xl sm:text-4xl font-medium text-primary leading-tight tracking-tight">
          Javi Barranco
        </h1>
        <p class="font-mono text-sm text-secondary mt-2">
          Software Engineer at <span class="text-accent">@Google</span>
        </p>
      </div>

      <p class="text-secondary text-sm leading-relaxed">
        Building distributed systems and data pipelines for
        Gemini Code Assist in Warsaw. CS + Mathematics.
      </p>

      <SocialLinks />

    </div>
  </div>

  <!--
    Blob canvas is injected into this container by blob.ts.
    Positioned absolutely so it is not bounded by the text column and
    can bleed beyond the right viewport edge (clipped by overflow-hidden).
    Mobile: centred behind text. Desktop: anchored at 48% from left.
  -->
  <div
    id="blob-container"
    class="pointer-events-none absolute top-1/2 -translate-y-[48%]
           right-1/2 translate-x-1/2
           w-[min(75vw,20rem)] h-[min(75vw,20rem)]
           sm:w-[min(65vw,24rem)] sm:h-[min(65vw,24rem)]
           lg:left-[48%] lg:right-auto lg:translate-x-0
           lg:w-[34rem] lg:h-[34rem]"
    aria-hidden="true"
  ></div>

</section>

<script>
  import { initBlob } from '../lib/blob';
  const container = document.getElementById('blob-container');
  if (container) initBlob(container).catch(console.error);
</script>
