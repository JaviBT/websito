---
---

<section class="relative min-h-screen flex items-center pt-12 overflow-hidden">

  <!-- Text: z-10 so it sits above the blob when they overlap -->
  <div class="relative z-10 max-w-4xl mx-auto px-6 w-full">
    <div class="space-y-7 max-w-xs sm:max-w-sm">

      <div>
        <h1 class="font-mono text-3xl sm:text-4xl font-medium text-primary leading-tight tracking-tight">
          Javi Barranco
        </h1>
        <p class="font-mono text-sm text-secondary mt-2">
          Software Engineer at <span class="text-accent">@Google</span>
        </p>
      </div>

      <p class="text-secondary text-sm leading-relaxed">
        Building distributed systems and data pipelines for
        Gemini Code Assist in Warsaw.
        CS + Mathematics.
      </p>

      <!-- Social links -->
      <div class="flex items-center gap-3">
        <a
          href="mailto:javibarrancotena@gmail.com"
          class="site-link p-2"
          aria-label="Email"
          title="Email"
        >
          <!-- Envelope -->
          <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect x="2" y="4" width="20" height="16" rx="2"/>
            <path d="m2 7 10 7 10-7"/>
          </svg>
        </a>

        <a
          href="https://github.com/JaviBT"
          target="_blank"
          rel="noopener noreferrer"
          class="site-link p-2"
          aria-label="GitHub"
          title="GitHub"
        >
          <!-- GitHub mark -->
          <svg width="17" height="17" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 0C5.37 0 0 5.37 0 12c0 5.3 3.44 9.8 8.21 11.39.6.11.79-.26.79-.58v-2.23c-3.34.72-4.03-1.42-4.03-1.42-.55-1.39-1.34-1.76-1.34-1.76-1.09-.74.08-.73.08-.73 1.2.09 1.84 1.24 1.84 1.24 1.07 1.83 2.81 1.3 3.49 1 .11-.78.42-1.31.76-1.61-2.67-.3-5.47-1.33-5.47-5.93 0-1.31.47-2.38 1.24-3.22-.12-.3-.54-1.52.12-3.18 0 0 1.01-.32 3.3 1.23a11.5 11.5 0 0 1 3-.4c1.02 0 2.05.14 3 .4 2.28-1.55 3.29-1.23 3.29-1.23.66 1.66.24 2.88.12 3.18.77.84 1.23 1.91 1.23 3.22 0 4.61-2.81 5.63-5.48 5.92.43.37.82 1.1.82 2.22v3.29c0 .32.19.69.8.58C20.56 21.8 24 17.3 24 12c0-6.63-5.37-12-12-12z"/>
          </svg>
        </a>

        <a
          href="https://linkedin.com/in/francisco-javier-barranco-tena"
          target="_blank"
          rel="noopener noreferrer"
          class="site-link p-2"
          aria-label="LinkedIn"
          title="LinkedIn"
        >
          <!-- LinkedIn mark -->
          <svg width="17" height="17" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M20.45 20.45h-3.55v-5.57c0-1.33-.03-3.04-1.85-3.04-1.85 0-2.13 1.44-2.13 2.94v5.67H9.37V9h3.41v1.56h.05c.48-.9 1.64-1.85 3.37-1.85 3.6 0 4.27 2.37 4.27 5.45v6.29zM5.34 7.43a2.06 2.06 0 1 1 0-4.12 2.06 2.06 0 0 1 0 4.12zM7.12 20.45H3.56V9h3.56v11.45zM22.22 0H1.77C.79 0 0 .77 0 1.73v20.54C0 23.23.79 24 1.77 24h20.45C23.2 24 24 23.23 24 22.27V1.73C24 .77 23.2 0 22.22 0z"/>
          </svg>
        </a>
      </div>

    </div>
  </div>

  <!-- Blob: absolutely positioned, NOT inside the text grid column -->
  <div
    id="blob-container"
    class="pointer-events-none absolute top-1/2 -translate-y-[48%]
           right-1/2 translate-x-1/2
           w-[min(75vw,20rem)] h-[min(75vw,20rem)]
           sm:w-[min(65vw,24rem)] sm:h-[min(65vw,24rem)]
           lg:left-[48%] lg:right-auto lg:translate-x-0
           lg:w-[34rem] lg:h-[34rem]"
    aria-hidden="true"
  >
    <!-- canvas injected by blob.ts -->
  </div>

</section>

<script>
  import { initBlob } from '../lib/blob';
  const container = document.getElementById('blob-container');
  if (container) initBlob(container).catch(console.error);
</script>
