---
---

<section class="min-h-screen flex items-center pt-12">
  <div class="max-w-4xl mx-auto px-6 w-full">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center py-16 lg:py-0">

      <!-- Left: text -->
      <div class="space-y-8">
        <!-- ASCII label -->
        <div class="font-mono text-xs text-muted tracking-widest uppercase">
          ┌─ portfolio ─────────────────┐
        </div>

        <!-- Name -->
        <div>
          <h1 class="font-mono text-3xl sm:text-4xl font-medium text-primary leading-tight tracking-tight">
            Javi Barranco
          </h1>
          <p class="font-mono text-sm text-secondary mt-2">
            Software Engineer at{' '}
            <span class="text-accent">@Google</span>
          </p>
        </div>

        <!-- Brief -->
        <p class="text-secondary text-sm leading-relaxed max-w-xs">
          Building distributed systems and data pipelines for
          Gemini Code Assist in Warsaw.
          CS + Mathematics graduate.
        </p>

        <!-- Links -->
        <div class="flex items-center gap-6 pt-2">
          <a
            href="#work"
            class="font-mono text-xs text-accent border border-accent/30 hover:border-accent/60 px-4 py-2 transition-colors"
          >
            view work →
          </a>
          <a
            href="mailto:javibarrancotena@gmail.com"
            class="font-mono text-xs text-secondary hover:text-primary transition-colors"
          >
            get in touch
          </a>
        </div>

        <!-- ASCII closing -->
        <div class="font-mono text-xs text-muted tracking-widest">
          └─────────────────────────────┘
        </div>
      </div>

      <!-- Right: 3D blob -->
      <div class="flex items-center justify-center lg:justify-end">
        <div
          id="blob-container"
          class="w-72 h-72 sm:w-80 sm:h-80 lg:w-96 lg:h-96 relative"
          aria-hidden="true"
        >
          <!-- Canvas injected by blob.ts -->
        </div>
      </div>

    </div>

    <!-- Section divider -->
    <div class="ascii-divider mt-16 lg:mt-24">
      <span>scroll</span>
    </div>
  </div>
</section>

<script>
  import { initBlob } from '../lib/blob';
  const container = document.getElementById('blob-container');
  if (container) initBlob(container);
</script>
