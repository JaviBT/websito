---
const links = [
  { label: 'work',    href: '#work', glitch: false },
  { label: 'writing', href: null,    glitch: true  },
];

// Target text must match the source label's character count to prevent layout shift.
// 'writing' (7 chars) → '// wip.' (7 chars)
const glitchTarget: Record<string, string> = {
  writing: '// wip.',
};
---

<header class="fixed top-0 left-0 right-0 z-50 border-b border-border bg-bg/80 backdrop-blur-sm">
  <nav class="max-w-4xl mx-auto px-6 h-12 flex items-center justify-between">

    <a
      href="/"
      data-glitch-brand
      class="font-mono text-sm text-accent font-medium active:opacity-40 tracking-tight"
      aria-label="Home"
    >
      javibarranco
    </a>

    <ul class="flex items-center gap-6">
      {links.map(link => (
        <li>
          {link.glitch ? (
            <button
              data-glitch-btn
              data-original={link.label}
              data-target={glitchTarget[link.label]}
              class="site-link tracking-wide cursor-pointer bg-transparent border-none p-0 tabular-nums"
              style={`min-width: ${link.label.length}ch`}
            >
              {link.label}
            </button>
          ) : (
            <a href={link.href!} class="site-link tracking-wide">
              {link.label}
            </a>
          )}
        </li>
      ))}
    </ul>

  </nav>
</header>

<script>
  import { initBrandGlitch, initNavGlitch } from '../lib/glitch';

  const brand = document.querySelector<HTMLAnchorElement>('[data-glitch-brand]');
  if (brand) initBrandGlitch(brand);
  initNavGlitch();
</script>
