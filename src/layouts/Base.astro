---
export interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Javi Barranco — Software Engineer',
  description = 'Software Engineer at Google. Building distributed systems and data pipelines for Gemini Code Assist.',
} = Astro.props;

const canonicalURL = Astro.url;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="author" content="Francisco Javier Barranco Tena" />

    <!-- OG -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <link rel="canonical" href={canonicalURL} />

    <title>{title}</title>
  </head>
  <body class="min-h-screen bg-bg text-primary antialiased">
    <slot />
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
