---
import Base from '../../layouts/Base.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<Base title="Writing — Javi Barranco" description="Thoughts on systems, data, and building.">
  <Nav />
  <main class="max-w-4xl mx-auto px-6 pt-24 pb-16">
    <div class="ascii-divider mb-12">
      <span>writing</span>
    </div>

    {posts.length === 0 ? (
      <p class="font-mono text-sm text-muted text-center py-16">no posts yet — check back soon.</p>
    ) : (
      <div class="space-y-6">
        {posts.map(post => (
          <a
            href={`/blog/${post.slug}`}
            class="flex flex-col sm:flex-row sm:items-baseline sm:justify-between gap-1 group border-b border-border pb-6 last:border-0"
          >
            <div>
              <span class="font-mono text-sm text-primary group-hover:text-accent transition-colors block">
                {post.data.title}
              </span>
              <span class="text-xs text-secondary mt-1 block">{post.data.description}</span>
            </div>
            <span class="font-mono text-xs text-muted shrink-0">
              {post.data.date.toLocaleDateString('en-GB', { year: 'numeric', month: 'short' })}
            </span>
          </a>
        ))}
      </div>
    )}
  </main>
  <Footer />
</Base>
